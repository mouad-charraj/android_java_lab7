<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_container_mouad"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/star_background"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_mouad"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/star_primary"
        android:elevation="4dp"
        android:paddingTop="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:theme="@style/StarToolbarTheme"
        app:titleTextColor="@color/white" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycle_view_mouad"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/signature_mouad_view"
        app:layout_constraintTop_toBottomOf="@id/toolbar_mouad" />

    <TextView
        android:id="@+id/signature_mouad_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/star_primary"
        android:gravity="center"
        android:padding="12dp"
        android:text="Réalisé par CHARRAJ Mouad aka ZERO-XR7"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="italic"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
